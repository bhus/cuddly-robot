\begin_layout Itemize

\series bold
When to use it
\series default
:
 Finding a record by ID,
 optional configuration fields,
 or a search result.
\end_layout

\begin_layout Itemize

\series bold
The Downside
\series default
:
 It doesn't tell you 
\emph on
